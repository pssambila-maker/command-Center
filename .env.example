# Command Center — Environment Variables
# Copy this file to .env and fill in values before starting the server.
# .env is git-ignored and must NEVER be committed.

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Admin Log Viewer Credentials ─────────────────────────────────────────
# Protects /admin/logs and /admin/logs/export (HTTP Basic Auth)
# Change both values before going live.
ADMIN_USER=admin
ADMIN_PASS=changeme

# ── Log Rotation ─────────────────────────────────────────────────────────
# Rotate access.log when it reaches this size (in MB). Default: 50
MAX_LOG_MB=50
